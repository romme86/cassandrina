# ============================================================
# Cassandrina — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Database ---
POSTGRES_USER=cassandrina
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cassandrina
DATABASE_URL=postgresql://cassandrina:changeme@timescaledb:5432/cassandrina

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LND (Lightning Network Daemon) ---
# Connect to your existing LND node's REST API
LND_HOST=192.168.1.100          # IP of your Pi running LND
LND_PORT=8080                    # LND REST port (default 8080)
LND_MACAROON_HEX=               # hex-encoded invoice.macaroon (scope: invoices:read invoices:write)
LND_TLS_CERT_PATH=/path/to/tls.cert  # optional if using self-signed cert

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true            # set to false for production

# --- Polymarket ---
POLYMARKET_API_KEY=             # optional, public endpoints don't require auth

# --- Trading Bot ---
SCHEDULER_TIMEZONE=UTC          # IANA timezone for daily triggers, e.g. Europe/Rome
PREDICTION_TARGET_HOUR=16       # local hour in SCHEDULER_TIMEZONE when BTC price is evaluated
PREDICTION_OPEN_HOUR=8          # local hour in SCHEDULER_TIMEZONE when daily prediction window opens
PREDICTION_WINDOW_HOURS=6       # hours the window stays open
MIN_SATS=100                    # minimum sats for a valid prediction
MAX_SATS=5000                   # maximum sats (denominator for congruency)
WEEKLY_VOTE_DAY=6               # 0=Monday … 6=Sunday
WEEKLY_VOTE_HOUR=20             # local hour in SCHEDULER_TIMEZONE for weekly vote trigger
REPORT_HOURS_BEFORE_TARGET=8    # hours before target to send portfolio report

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=         # target Telegram group or supergroup chat ID
TELEGRAM_ADMIN_USER_IDS=        # comma-separated Telegram user IDs allowed to run admin bot commands

# --- Webapp ---
WEBAPP_API_URL=http://webapp:3000
NEXTAUTH_SECRET=changeme        # minimum 32-char random string
NEXTAUTH_URL=http://localhost:3000
ADMIN_PIN=1234                  # PIN to access the Config page in the dashboard
INTERNAL_API_SECRET=changeme    # shared secret for bot-to-webapp admin endpoints
